// Core enums
export type Cadence = 'Weekly' | 'Monthly' | 'Quarterly' | 'SemiAnnual' | 'Annual';

export type Category = 'ManagingBusiness' | 'ManagingTeam';

// KPI structure
export interface KPI {
  name: string;
  target: number; // percentage (e.g., 90 = 90%)
  description?: string;
}

// Task / Activity
export interface Activity {
  name: string;
  description?: string;
  cadence: Cadence;
  category: Category;
  tools?: string[];
}

// Dashboard / Reports
export interface Dashboard {
  name: string;
  purpose: string;
}

// Main Operating Rhythm संरcture
export interface OperatingRhythm {
  kpis: KPI[];
  dashboards: Dashboard[];
  activities: Activity[];
}

